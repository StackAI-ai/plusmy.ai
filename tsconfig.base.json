{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "declaration": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@plusmy/ui": ["packages/ui/src/index.tsx"],
      "@plusmy/config": ["packages/config/src/index.ts"],
      "@plusmy/contracts": ["packages/contracts/src/index.ts"],
      "@plusmy/supabase": ["packages/supabase/src/index.ts"],
      "@plusmy/core": ["packages/core/src/index.ts"],
      "@plusmy/integrations": ["packages/integrations/src/index.ts"],
      "@plusmy/mcp": ["packages/mcp/src/index.ts"]
    }
  }
}
